---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Menu from '../components/Menu.astro';
import StickyHeader from '../components/StickyHeader.astro';
import PortfolioItem from '../components/PortfolioItem.astro';
import Sidebar from '../components/Sidebar.astro';

const newsletter = await getCollection('newsletter', ({ data }) => !data.draft);
const work = await getCollection('work', ({ data }) => data.featured);

const menuItems = [
  { label: 'Work', href: '/work' },
	{ label: 'Newsletter', href: '/newsletter' },
  ...(await getCollection('pages', ({ data }) => data.inmenu)).map((page) => ({
    label: page.data.title,
    href: '/' + page.id,
  }))
];

const siteTitle = (await getCollection('settings', (data) => (data.id == 'title')))[0].data;
const siteDescription = (await getCollection('settings', (data) => (data.id == 'description')))[0].data;
---

<BaseLayout title={siteTitle} description={siteDescription} >
  <div class="blog">
    <Menu 
      items={menuItems}
    />
	
	<div class="blog-main">
		<div class="blog-header blog-is-sticky">
		  <div class="blog-article header-article">
		    <div class="blog-big__title">{siteTitle}</div>
		  </div>
		</div>

	    <div class="blog-header-container">
	      {
	        work.map((item) => (
	          <PortfolioItem
	            title={item.data.title}
	            date={item.data.date}
	            image={item.data.image}
	            summary={item.data.summary}
				order={item.data.order}
	            href={`/work/${item.id}`}
	          />
	        ))
	      }
	    </div>
		<div class="blog-main-footer">
	    <a href="/work">
	      <svg
	        xmlns="http://www.w3.org/2000/svg"
	        fill="none"
	        stroke="currentColor"
	        stroke-width="2"
	        stroke-linecap="round"
	        stroke-linejoin="round"
	        class="feather feather-corner-down-right"
	        viewBox="0 0 24 24"
	      >
	        <path d="M15 10l5 5-5 5"></path>
	        <path d="M4 4v7a4 4 0 004 4h12"></path>
	      </svg>
	      See More Work
	    </a>
		</div>
	</div>

    <Sidebar entries={newsletter} />
  </div>
</BaseLayout>
