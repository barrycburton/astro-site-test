---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const work = await getCollection('work');
  const tags = new Set<string>();
  posts.forEach((p) => p.data.tags.forEach((t) => tags.add(t)));
  work.forEach((i) => i.data.tags.forEach((t) => tags.add(t)));

  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => +b.data.date - +a.data.date),
	  work: work
	    .filter((i) => i.data.tags.includes(tag))
	    .sort((a, b) => +b.data.date - +a.data.date),
    },
  }));
}

const { tag, posts, work } = Astro.props;
const fmt = (d: Date) =>
  `${String(d.getDate()).padStart(2, '0')}.${String(d.getMonth() + 1).padStart(2, '0')}.${d.getFullYear()}`;
---

<PageLayout
  title={`#${tag}`}
  eyebrow="Tag"
  description={`${posts.length} item${posts.length === 1 ? '' : 's'} tagged ${tag}.`}
>
  <div class="post-list">
    {
      posts.map((post) => (
        <a class="post-card" href={`/newsletter/${post.id}`}>
          <div class="post-card__cover">
            <img src={post.data.cover} alt="" loading="lazy" />
          </div>
          <div>
            <div class="post-card__meta">
              {fmt(post.data.date)} · {post.data.author}
            </div>
            <h2 class="post-card__title">{post.data.bigTitle}</h2>
            <p class="post-card__excerpt">{post.data.excerpt}</p>
          </div>
        </a>
      ))
    }
 </div>
 <div class="post-list">
    {
      work.map((item) => (
        <a class="post-card" href={`/work/${item.id}`}>
          <div class="post-card__cover">
            <img src={item.data.cover} alt="" loading="lazy" />
          </div>
          <div>
            <div class="post-card__meta">
              {fmt(item.data.date)}
            </div>
            <h2 class="post-card__title">{item.data.title}</h2>
            <p class="post-card__excerpt">{item.data.summary}</p>
          </div>
        </a>
      ))
    }
  </div>
</PageLayout>
