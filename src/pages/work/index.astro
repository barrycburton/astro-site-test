---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const newsletter = (await getCollection('newsletter')).sort(
  (a, b) => +b.data.date - +a.data.date,
);

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);

---

<PageLayout
  title="Work"
>
  {
    work.length === 0 ? (
      <p>
        No work entries yet. Add markdown files to <code>src/content/work/</code>
        with <code>title</code>, <code>year</code>, <code>image</code>, and
        <code>summary</code> fields.
      </p>
    ) : (
      <div class="work-grid">
        {work.map((item) => {
          return (
            <a
              class="work-item"
              href={`/work/${item.id}`}}
            >
              <img src={item.data.image} alt="" loading="lazy" />
              <div class="work-item__year">{item.data.year}</div>
              <div class="work-item__title">{item.data.title}</div>
            </a>
          );
        })}
      </div>
    )
  }
</PageLayout>
