---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteTitle = (await getCollection('settings', (data) => (data.id == 'title')))[0].data;
---

<BaseLayout title="Lost — {siteTitle}" description="The page you were looking for isn't here." siteTitle={siteTitle} >
  <div class="not-found">
    <div class="not-found__code">404</div>
    <a href="/">← Back home</a>
  </div>
</BaseLayout>
