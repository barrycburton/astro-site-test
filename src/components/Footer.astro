---
interface FooterItem {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  siteTitle: string;
  items?: FooterItem[];
}

const { siteTitle, items } = Astro.props;

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand"></div>
    <nav class="site-footer__nav" aria-label="Footer">
      {
        items.map((item) => (
          <a href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="site-footer__meta">© {year} {siteTitle}</div>
  </div>
</footer>
