---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  image?: string;
}

const menuItems = [
  { label: 'Work', href: '/work' },
	{ label: 'Newsletter', href: '/newsletter' },
  ...(await getCollection('pages', ({ data }) => data.inmenu)).map((page) => ({
    label: page.data.title,
    href: '/' + page.id,
  }))
];

const footerItems = [
  { label: 'Home', href: '/' },
  ...menuItems,
];

const siteTitle = (await getCollection('settings', (data) => (data.id == 'title')))[0].data;

const { title, description, eyebrow, image, } = Astro.props;
const headTitle = `${title} — ${siteTitle}`;
---

<BaseLayout title={headTitle} description={description} image={image}>
  <div class="page">
    <header class="page-nav">
      <a class="page-nav__brand" href="/">{siteTitle}</a>
      <nav aria-label="Primary">
        {
          menuItems.map((item) => (
            <a href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main class="page-main">
      {
        image && (
          <div class="page-image">
            <img src={image} alt="" />
          </div>
        )
      }

      <section class="page-head">
        {eyebrow && <div class="page-eyebrow">{eyebrow}</div>}
        <h1 class="page-title" data-editable="text" data-prop="title">{title}</h1>
        {description && <p class="page-deck">{description}</p>}
      </section>

      <div class="page-body">
        <slot />
      </div>
    </main>

    <Footer items={footerItems} siteTitle={siteTitle} />
  </div>
</BaseLayout>
